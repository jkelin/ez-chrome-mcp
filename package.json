{
  "name": "ez-chrome-mcp",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run concurrently.config.ts",
    "watch": "bun --watch index.ts",
    "start": "bun run index.ts",
    "inspector": "mcp-inspector --config inspector.config.json --server ez-chrome-mcp",
    "typecheck": "tsc --noEmit",
