{
  "name": "ez-chrome-mcp",
  "version": "0.2.1",
  "description": "MCP server for debugging live Chrome tabs — list targets, read console logs, evaluate JavaScript, and capture screenshots over CDP.",
  "type": "module",
  "license": "MIT",
  "author": "Jan Kelin <jan@jkelin.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkelin/ez-chrome-mcp.git"
  },
  "homepage": "https://github.com/jkelin/ez-chrome-mcp#readme",
  "bugs": {
    "url": "https://github.com/jkelin/ez-chrome-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome",
    "chromium",
    "cdp",
    "devtools",
    "debugging",
    "cursor",
    "playwright",
    "browser-automation"
  ],
  "bin": {
    "ez-chrome-mcp": "./bin/ez-chrome-mcp.ts"
  },
  "files": [
    "bin",
    "index.ts",
    "src",
    "mcp.json",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run concurrently.config.ts",
    "watch": "bun --watch index.ts",
    "start": "bun run index.ts",
    "inspector": "mcp-inspector --config inspector.config.json --server ez-chrome-mcp",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  }
}